<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN"
        "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
<head>
    <meta http-equiv="content-type" content="text/html" />
    <title>{{ site.siteName }}: {{ group.name }}</title>

<script type="text/javascript">
var andSoItBegins = (new Date()).getTime();
</script>
    <link rel="shortcut icon" href="{{ site.webGalleryPath }}/v2/favicon.ico" type="image/vnd.microsoft.icon" />
<script src="{{ site.webGalleryPath }}/static/js/libs2.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/visual.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/libs.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/common.js" type="text/javascript"></script>
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/style.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/buttons.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/boxes.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/tooltips.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/styles/local/group.css" type="text/css" />

<script type="text/javascript">
document.habboLoggedIn = {{ session.loggedIn }};
var habboName = {% if session.loggedIn %}"{{ playerDetails.name }}"{% else %}null{% endif %};
var habboReqPath = "{{ site.sitePath }}";
var habboStaticFilePath = "{{ site.webGalleryPath }}";
var habboImagerUrl = "{{ site.habboImagingPath }}/";
window.name = "habboMain";
if (typeof HabboClient != "undefined") { HabboClient.windowName = "client"; }
</script>

<meta name="description" content="{{ group.name }} on {{ site.siteName }}" />
<meta name="keywords" content="{{ site.siteName }}, group, {{ group.name }}, tags, members" />
<meta name="build" content="Vibe" />
</head>
<body id="group-page" class=" ">
{% include "base/header.peb" %}
<div id="content-container">
    {% include "base/subnav.peb" %}
    <div id="container">
        <div id="content" class="clearfix">
            <div id="column1" class="column">
                <div class="habblet-container ">
                    <div class="cbb clearfix blue ">
                        <h2 class="title">{{ group.name }}</h2>
                        <div class="group-page-summary clearfix">
                            <div class="group-page-badge" style="background-image: url({{ site.sitePath }}/habbo-imaging/badge/{{ group.badge }}.gif)"></div>
                            <div class="group-page-copy">
                                <p>{{ group.description }}</p>
                                <p class="group-page-meta">Members: <strong>{{ group.memberCount }}</strong></p>
                                {% if group.ownerName != "" %}
                                <p class="group-page-meta">Owner: <a href="{{ group.ownerUrl }}">{{ group.ownerName }}</a></p>
                                {% endif %}
                                {% if group.roomId > 0 %}
                                <p class="group-page-meta">Associated room: <a href="{{ site.sitePath }}/client?forwardId=2&amp;roomId={{ group.roomId }}" onclick="HabboClient.roomForward(this, '{{ group.roomId }}', 'private'); return false;" target="client">{{ group.roomName }}</a></p>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>

                <div class="habblet-container ">
                    <div class="cbb clearfix green ">
                        <h2 class="title">Tags</h2>
                        <div class="box-content">
                            {% if group.tags | length > 0 %}
                            <ul class="tag-list">
                            {% for tag in group.tags %}
                                <li><a href="{{ site.sitePath }}/tag/{{ tag }}" class="tag">{{ tag }}</a></li>
                            {% endfor %}
                            </ul>
                            {% else %}
                            <p class="group-page-empty">This group has no public tags yet.</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
                <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>
            </div>
            <div id="column2" class="column">
                <div class="habblet-container ">
                    <div class="cbb clearfix orange ">
                        <h2 class="title">Members</h2>
                        <div class="box-content">
                            {% if group.members | length > 0 %}
                            <ul class="group-page-members">
                            {% for member in group.members %}
                                <li>
                                    <img alt="{{ member.name }}" src="{{ site.sitePath }}/habbo-imaging/avatarimage?figure={{ member.figure }}&size=s&direction=4&head_direction=4&gesture=sml" />
                                    <a href="{{ member.url }}">{{ member.name }}</a>
                                </li>
                            {% endfor %}
                            </ul>
                            {% else %}
                            <p class="group-page-empty">This group does not have visible members yet.</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
                <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>
            </div>
        </div>
    </div>
{% include "base/footer.peb" %}

<script type="text/javascript">
HabboView.run();
</script>
</body>
</html>
