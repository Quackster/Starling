<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN"
        "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
<head>
    <meta http-equiv="content-type" content="text/html; charset=utf-8" />
    <title>{{ site.siteName }}: {{ clientUtils.pageName }}</title>

    <script type="text/javascript">
    var andSoItBegins = (new Date()).getTime();
    </script>
    <link rel="shortcut icon" href="{{ site.webGalleryPath }}/v2/favicon.ico" type="image/vnd.microsoft.icon" />
    <link rel="alternate" type="application/rss+xml" title="{{ site.siteName }}: RSS" href="{{ site.sitePath }}/articles/rss.xml" />
    <script src="{{ site.webGalleryPath }}/static/js/libs2.js" type="text/javascript"></script>
    <script src="{{ site.webGalleryPath }}/static/js/visual.js" type="text/javascript"></script>
    <script src="{{ site.webGalleryPath }}/static/js/libs.js" type="text/javascript"></script>
    <script src="{{ site.webGalleryPath }}/static/js/common.js" type="text/javascript"></script>
    <script src="{{ site.webGalleryPath }}/static/js/fullcontent.js" type="text/javascript"></script>
    <link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/style.css" type="text/css" />
    <link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/buttons.css" type="text/css" />
    <link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/boxes.css" type="text/css" />
    <link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/tooltips.css" type="text/css" />
    <link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/habboclient.css" type="text/css" />
    <script src="{{ site.webGalleryPath }}/static/js/habboclient.js" type="text/javascript"></script>

    <script type="text/javascript">
    document.habboLoggedIn = true;
    var habboName = "{{ clientUtils.habboName }}";
    var ad_keywords = "";
    var habboReqPath = "{{ site.sitePath }}";
    var habboStaticFilePath = "{{ site.webGalleryPath }}";
    var habboImagerUrl = "{{ site.habboImagingPath }}/";
    var habboPartner = "";
    window.name = "client";
    if (typeof HabboClient != "undefined") { HabboClient.windowName = "client"; }
    </script>

    <meta name="description" content="Join the world's largest virtual hangout where you can meet and make friends. Design your own rooms, collect cool furniture, throw parties and so much more! Create your FREE {{ site.siteName }} today!" />
    <meta name="keywords" content="{{ site.siteName }}, virtual, world, join, groups, forums, play, games, online, friends, teens, collecting, social network, create, collect, connect, furniture, virtual, goods, sharing, badges, social, networking, hangout, safe, music" />

    <!--[if IE 8]>
    <link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/ie8.css" type="text/css" />
    <![endif]-->
    <!--[if lt IE 8]>
    <link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/ie.css" type="text/css" />
    <![endif]-->
    <!--[if lt IE 7]>
    <link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/ie6.css" type="text/css" />
    <script src="{{ site.webGalleryPath }}/static/js/pngfix.js" type="text/javascript"></script>
    <script type="text/javascript">
    try { document.execCommand('BackgroundImageCache', false, true); } catch(e) {}
    </script>

    <style type="text/css">
    body { behavior: url({{ site.webGalleryPath }}/js/csshover.htc); }
    </style>
    <![endif]-->
</head>
<body id="popup" class="process-template client_error">
<div id="container">
    <div id="content">
        <div id="process-content" class="centered-client-error">
            <div id="column1" class="column">
                <div class="habblet-container">
                    <div class="cbb clearfix orange">
                        {% if clientUtils.key == "install_shockwave" %}
                        <h2 class="title">Shockwave detection</h2>
                        <div class="box-content">
                            <div>
                                <p>Oops, in order to enter the hotel you need <b>Adobe Shockwave player</b>.</p>
                                <p>Shockwave is free and takes only a <b>minute or two</b> to install.</p>
                            </div>
                            <div id="swdetection"></div>
                            <div class="install-shockwave">
                                <div id="shockwave-install-button">
                                    <div class="shockwave-icon">
                                        <a class="new-button" href="#" id="install-shockwave-link"><b>Install now</b><i></i></a>
                                    </div>
                                </div>
                                <div id="shockwave-install-progressbar">
                                    <div class="shockwave-icon progressbar"><span class="install-label">Installing</span><img src="{{ site.webGalleryPath }}/images/progress_bar_blue.gif" alt="" width="100" height="20" /></div>
                                </div>
                            </div>
                        </div>
                        <script type="text/javascript">
                        ShockwaveInstallation.detectionFile = '{{ site.webGalleryPath }}/shockwave/detect_shockwave.dcr';
                        ShockwaveInstallation.cabVersion = '10,0,0,0';
                        ShockwaveInstallation.clientURL = '{{ site.sitePath }}/client';
                        ShockwaveInstallation.init();
                        ShockwaveInstallation.playerVersion = '11';
                        Event.observe("install-shockwave-link", "click", function(e) {Event.stop(e); ShockwaveInstallation.startSwInstallation(); return false;});
                        $('column1').setStyle({width : '660px'});
                        </script>
                        <script type="text/javascript">
                        document.observe("dom:loaded", function() {
                            ClientMessageHandler.googleEvent("client_error", "shockwave_install");
                        });
                        </script>
                        {% elseif clientUtils.key == "upgrade_shockwave" %}
                        <h2 class="title">Shockwave detection</h2>
                        <div class="box-content">
                            <p>It appears that you have an old version of <b>Adobe Shockwave player</b> which is not compatible with {{ site.siteName }}. Please follow these steps to get a compatible player:</p>
                            <ul>
                                <li class="client_error"><span>shockwave.upgrade.info.step1</span></li>
                                <li class="client_error"><span>Save, open and then run the uninstaller file and follow the on screen instructions.</span></li>
                                <li class="client_error"><span>Close this browser window and open the hotel again. This should trigger an installation process to install a compatible version of the Shockwave player.</span></li>
                            </ul>
                        </div>
                        <script type="text/javascript">
                        document.observe("dom:loaded", function() {
                            ClientMessageHandler.googleEvent("client_error", "shockwave_upgrade");
                        });
                        </script>
                        {% elseif clientUtils.key == "error" %}
                        <h2 class="title">Oops!!</h2>
                        <div class="box-content">
                            <div class="info-client_error-text">
                                <p>Oops, the client encountered a technical problem. Not to worry this error has now been recorded to our system and will be investigated by our support team.</p>
                                <p>Please re-open <a onclick="openOrFocusHabbo(this); return false;" target="client" href="{{ site.sitePath }}/client">hotel</a> to continue. We are sorry for the inconvenience.</p>
                            </div>
                            <div class="retry-enter-hotel">
                                <div class="hotel-open">
                                    <a id="enter-hotel-open-image" class="open" href="{{ site.sitePath }}/client" target="client" onclick="HabboClient.openOrFocus(this); return false;">
                                        <div class="hotel-open-image-splash"></div>
                                        <div class="hotel-image hotel-open-image"></div>
                                    </a>
                                    <div class="hotel-open-button-content">
                                        <a class="open" href="{{ site.sitePath }}/client" target="client" onclick="HabboClient.openOrFocus(this); return false;">Enter</a>
                                        <span class="open"></span>
                                    </div>
                                </div>
                            </div>
                            {% if clientUtils.errorId %}
                            <script type="text/javascript">
                            document.observe("dom:loaded", function() {
                                var titles = $$("h2.title");
                                if (titles.length > 0) {
                                    Element.insert(titles[0], "(#{{ clientUtils.errorId }}) ");
                                }
                            });
                            </script>
                            {% endif %}
                        </div>
                        <script type="text/javascript">
                        document.observe("dom:loaded", function() {
                            ClientMessageHandler.googleEvent("client_error", "unknown");
                        });
                        </script>
                        {% else %}
                        <h2 class="title">{{ clientUtils.connectionTitle }}</h2>
                        <div class="box-content">
                            <p>{{ clientUtils.connectionMessage }} IP address: {{ clientUtils.hotelIp }}, TCP port: {{ clientUtils.hotelPort }}</p>
                        </div>
                        {% endif %}
                    </div>
                </div>
                <script type="text/javascript">
                if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }
                </script>
            </div>
            <script type="text/javascript">
            HabboView.run();
            </script>
            <div id="column2" class="column"></div>
        <!--[if lt IE 7]>
            <script type="text/javascript">
            Pngfix.doPngImageFix();
            </script>
        <![endif]-->
        </div>
    </div>
</div>
</body>
</html>
