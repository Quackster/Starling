<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN"
        "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
<head>
    <meta http-equiv="content-type" content="text/html; charset=utf-8" />
    <title>{{ site.siteName }}: Client</title>

    <script type="text/javascript">
    var andSoItBegins = (new Date()).getTime();
    </script>
    <link rel="shortcut icon" href="{{ site.webGalleryPath }}/v2/favicon.ico" type="image/vnd.microsoft.icon" />
    <link rel="alternate" type="application/rss+xml" title="{{ site.siteName }}: RSS" href="{{ site.sitePath }}/articles/rss.xml" />
    <script src="{{ site.webGalleryPath }}/static/js/libs2.js" type="text/javascript"></script>
    <script src="{{ site.webGalleryPath }}/static/js/visual.js" type="text/javascript"></script>
    <script src="{{ site.webGalleryPath }}/static/js/libs.js" type="text/javascript"></script>
    <script src="{{ site.webGalleryPath }}/static/js/common.js" type="text/javascript"></script>
    <script src="{{ site.webGalleryPath }}/static/js/fullcontent.js" type="text/javascript"></script>
    <link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/style.css" type="text/css" />
    <link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/buttons.css" type="text/css" />
    <link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/boxes.css" type="text/css" />
    <link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/tooltips.css" type="text/css" />
    <link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/habboclient.css" type="text/css" />
    <script src="{{ site.webGalleryPath }}/static/js/habboclient.js" type="text/javascript"></script>

    <script type="text/javascript">
    document.habboLoggedIn = true;
    var habboName = "{{ user.username }}";
    var ad_keywords = "";
    var habboReqPath = "{{ site.sitePath }}";
    var habboStaticFilePath = "{{ site.webGalleryPath }}";
    var habboImagerUrl = "{{ site.habboImagingPath }}/";
    var habboPartner = "";
    window.name = "client";
    if (typeof HabboClient != "undefined") { HabboClient.windowName = "client"; }
    </script>

    <script type="text/javascript">
    var habboClient = true;
    HabboClientUtils.init({remoteCallsEnabled : true, taggingGameEnabled : false});
    ffec.c("chrome://havvocmini/content/HavvocIcon.PNG");
    log(4);
    </script>
</head>
<body id="client"{% if wide %} class="wide"{% endif %}>

<div id="client-topbar" style="display:none">
    <div class="logo"><img src="{{ site.webGalleryPath }}/images/popup/popup_topbar_habbologo.gif" alt="" align="middle"/></div>
    <div class="habbocount"><div id="habboCountUpdateTarget">{{ onlineCount }} members online</div>
        <script type="text/javascript">
            setTimeout(function() {
                HabboCounter.init(600);
            }, 20000);
        </script>
    </div>
    <div class="logout"><a href="/account/logout?origin=popup" onclick="self.close(); return false;">Close hotel</a></div>
</div>
<noscript>
    <img src="/clientlog/nojs" border="0" width="1" height="1" alt="" style="position: absolute; top:0; left:0;" />
</noscript>

<div id="clientembed-container">
    <div id="clientembed-loader" class="loader-image" style="display:none">
        <div class="loader-image-inner">
            <b class="loading-text">Loading...</b>
        </div>
    </div>
    <div id="clientembed">
        <script type="text/javascript">
        try {
            var _shockwaveDetectionSuccessful = true;
            _shockwaveDetectionSuccessful = ShockwaveInstallation.swDetectionCheck();
            if (!_shockwaveDetectionSuccessful) {
                log(50);
            }
            if (_shockwaveDetectionSuccessful) {
                HabboClientUtils.cacheCheck();
            }
        } catch (e) {
            try {
                HabboClientUtils.logClientJavascriptError(e);
            } catch (e2) {}
        }

        HabboClientUtils.extWrite("<object classid=\"clsid:166B1BCA-3F9C-11CF-8075-444553540000\" codebase=\"http://download.macromedia.com/pub/shockwave/cabs/director/sw.cab#version=10,0,0,0\" id=\"Theme\" width=\"960\" height=\"540\"><param name=\"src\" value=\"{{ client.dcr }}\"><param name=\"swRemote\" value=\"swSaveEnabled='true' swVolume='true' swRestart='false' swPausePlay='false' swFastForward='false' swTitle='{{ site.siteName }} Hotel' swContextMenu='true' \"><param name=\"swStretchStyle\" value=\"stage\"><param name=\"swText\" value=\"\"><param name=\"bgColor\" value=\"#000000\"><param name=\"sw6\" value=\"client.connection.failed.url=/clientutils.php?key=connection_failed;external.variables.txt={{ client.externalVariables }}\"><param name=\"sw8\" value=\"use.sso.ticket=1;sso.ticket={{ user.ssoTicket }}\"><param name=\"sw2\" value=\"connection.info.host={{ client.hotelIp }};connection.info.port={{ client.hotelPort }}\"><param name=\"sw4\" value=\"site.url={{ site.sitePath }};url.prefix={{ site.sitePath }}\"><param name=\"sw3\" value=\"connection.mus.host={{ client.hotelIp }};connection.mus.port={{ client.hotelMusPort }}\"><param name=\"sw1\" value=\"client.allow.cross.domain=1;client.notify.cross.domain=0\"><param name=\"sw7\" value=\"external.texts.txt={{ client.externalTexts }}\"><param name=\"sw5\" value=\"client.reload.url=/client?x=reauthenticate;client.fatal.error.url=/clientutils.php?key=error\"><embed src=\"{{ client.dcr }}\" bgColor=\"#000000\" width=\"960\" height=\"540\" swRemote=\"swSaveEnabled='true' swVolume='true' swRestart='false' swPausePlay='false' swFastForward='false' swTitle='{{ site.siteName }} Hotel' swContextMenu='true'\" swStretchStyle=\"stage\" swText=\"\" type=\"application/x-director\" pluginspage=\"http://www.macromedia.com/shockwave/download/\" sw6=\"client.connection.failed.url=/clientutils.php?key=connection_failed;external.variables.txt={{ client.externalVariables }}\" sw8=\"use.sso.ticket=1;sso.ticket={{ user.ssoTicket }}\" sw2=\"connection.info.host={{ client.hotelIp }};connection.info.port={{ client.hotelPort }}\" sw4=\"site.url={{ site.sitePath }};url.prefix={{ site.sitePath }}\" sw3=\"connection.mus.host={{ client.hotelIp }};connection.mus.port={{ client.hotelMusPort }}\" sw1=\"client.allow.cross.domain=1;client.notify.cross.domain=0\" sw7=\"external.texts.txt={{ client.externalTexts }}\" sw5=\"client.reload.url=/client?x=reauthenticate;client.fatal.error.url=/clientutils.php?key=error\"></embed><noembed>Shockwave is required.</noembed></object>");
        </script>
        <noscript>
            <object classid="clsid:166B1BCA-3F9C-11CF-8075-444553540000" codebase="http://download.macromedia.com/pub/shockwave/cabs/director/sw.cab#version=10,0,0,0" id="Theme" width="960" height="540">
                <param name="src" value="{{ client.dcr }}">
                <param name="swRemote" value="swSaveEnabled='true' swVolume='true' swRestart='false' swPausePlay='false' swFastForward='false' swTitle='{{ site.siteName }} Hotel' swContextMenu='true' ">
                <param name="swStretchStyle" value="stage">
                <param name="swText" value="">
                <param name="bgColor" value="#000000">
                <param name="sw6" value="client.connection.failed.url=/clientutils.php?key=connection_failed;external.variables.txt={{ client.externalVariables }}">
                <param name="sw8" value="use.sso.ticket=1;sso.ticket={{ user.ssoTicket }}">
                <param name="sw2" value="connection.info.host={{ client.hotelIp }};connection.info.port={{ client.hotelPort }}">
                <param name="sw4" value="site.url={{ site.sitePath }};url.prefix={{ site.sitePath }}">
                <param name="sw3" value="connection.mus.host={{ client.hotelIp }};connection.mus.port={{ client.hotelMusPort }}">
                <param name="sw1" value="client.allow.cross.domain=1;client.notify.cross.domain=0">
                <param name="sw7" value="external.texts.txt={{ client.externalTexts }}">
                <param name="sw5" value="client.reload.url=/client?x=reauthenticate;client.fatal.error.url=/clientutils.php?key=error">
            </object>
        </noscript>
    </div>
</div>
<script type="text/javascript">
HabboClientUtils.loaderTimeout = {{ client.loaderTimeoutMs }};
HabboClientUtils.showLoader(["Loading", "Loading.", "Loading..", "Loading..."]);
</script>
</body>
</html>
