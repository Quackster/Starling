
<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN"
        "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
<head>
	<meta http-equiv="content-type" content="text/html" />
	{% if newsPage == "custom_event" %}
	<title>{{ site.siteName }}: Space Academy Points</title>	
	{% else %}
	<title>{{ site.siteName }}: News ~ {{ currentArticle.title }} </title>
	{% endif %}
	
<script type="text/javascript">
var andSoItBegins = (new Date()).getTime();
</script>
    <link rel="shortcut icon" href="{{ site.webGalleryPath }}/v2/favicon.ico" type="image/vnd.microsoft.icon" />
    <link rel="alternate" type="application/rss+xml" title="{{ site.siteName }}: RSS" href="{{ site.sitePath }}/articles/rss.xml" />
<script src="{{ site.webGalleryPath }}/static/js/libs2.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/visual.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/libs.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/common.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/fullcontent.js" type="text/javascript"></script>
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/style.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/buttons.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/boxes.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/tooltips.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/styles/local/com.css" type="text/css" />

<script src="{{ site.webGalleryPath }}/js/local/com.js" type="text/javascript"></script>

<script type="text/javascript">
document.habboLoggedIn = {{ session.loggedIn }};
var habboName = "a";
var ad_keywords = "";
var habboReqPath = "{{ site.sitePath }}";
var habboStaticFilePath = "{{ site.webGalleryPath }}";
var habboImagerUrl = "{{ site.habboImagingPath }}/";
var habboPartner = "";
window.name = "habboMain";
if (typeof HabboClient != "undefined") { HabboClient.windowName = "client"; }

</script>

<meta name="description" content="Join the world's largest virtual hangout where you can meet and make friends. Design your own rooms, collect cool furniture, throw parties and so much more! Create your FREE {{ site.siteName }} today!" />
<meta name="keywords" content="{{ site.siteName }}, virtual, world, join, groups, forums, play, games, online, friends, teens, collecting, social network, create, collect, connect, furniture, virtual, goods, sharing, badges, social, networking, hangout, safe, music, celebrity, celebrity visits, cele" />

<meta name="twitter:title" content="{{ currentArticle.title }}" />
<meta name="twitter:description" content="{{ currentArticle.shortstory }}" />
{% if currentArticle.articleImage != "" %}
<meta name="twitter:image" content="{{ currentArticle.articleImage }}" />
{% endif %}

<!--[if IE 8]>
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/ie8.css" type="text/css" />
<![endif]-->
<!--[if lt IE 8]>
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/ie.css" type="text/css" />
<![endif]-->
<!--[if lt IE 7]>
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/ie6.css" type="text/css" />
<script src="{{ site.webGalleryPath }}/static/js/pngfix.js" type="text/javascript"></script>
<script type="text/javascript">
try { document.execCommand('BackgroundImageCache', false, true); } catch(e) {}
</script>

<style type="text/css">
body { behavior: url({{ site.webGalleryPath }}/js/csshover.htc); }
</style>

<![endif]-->
<meta name="build" content="{{ site.siteName }}" />
</head>
{% if session.loggedIn == false %}
<body id="news" class="anonymous ">
{% else %}
<body id="news" class=" ">
{% endif %}
{% include "base/header.peb" %}
   
<div id="content-container">
{% if newsPage == "news" %}
{% set articleLink = "articles" %}
{% endif %}
{% if newsPage == "events" %}
{% set articleLink = "community/events" %}
{% endif %}
{% if newsPage == "fansites" %}
{% set articleLink = "community/fansites" %}
{% endif %}
{% include "base/subnav.peb" %}

	
<div id="container">
	<div id="content" style="position: relative" class="clearfix">
        {% include "fragments/page_columns.peb" %}
<script type="text/javascript">
HabboView.run();
</script>
<script type="text/javascript">
HabboView.run();

</script>

<!--[if lt IE 7]>
<script type="text/javascript">
Pngfix.doPngImageFix();
</script>
<![endif]-->

    </div>
{% include "base/footer.peb" %}

<script type="text/javascript">
HabboView.run();
</script>


</body>
</html>

