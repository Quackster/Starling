<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN"
        "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
<head>
    <meta http-equiv="content-type" content="text/html" />
    <title>{{ site.siteName }}: Community</title>

<script type="text/javascript">
var andSoItBegins = (new Date()).getTime();
</script>
<script src="{{ site.webGalleryPath }}/static/js/visual.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/libs.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/common.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/fullcontent.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/libs2.js" type="text/javascript"></script>
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/style.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/buttons.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/boxes.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/tooltips.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/styles/local/com.css" type="text/css" />

<script type="text/javascript">
document.habboLoggedIn = {{ session.loggedIn }};
var habboName = "{{ site.playerName }}";
var habboReqPath = "{{ site.sitePath }}";
var habboStaticFilePath = "{{ site.webGalleryPath }}";
var habboImagerUrl = "{{ site.habboImagingPath }}/";
var habboPartner = "";
window.name = "habboMain";
</script>

<meta name="description" content="{{ site.siteName }} is a virtual world where you can meet and make friends." />
<meta name="keywords" content="{{ site.siteName }}, community, groups, rooms, news" />
<meta name="build" content="HavanaWeb" />
</head>
{% if session.loggedIn == false %}
<body id="community" class="anonymous ">
{% else %}
<body id="community" class=" ">
{% endif %}

{% include "base/header.peb" %}

<div id="content-container">
    <div id="container">
        <div id="content" style="position: relative" class="clearfix">
            <div id="column1" class="column">
                <div class="habblet-container ">
                    <div class="cbb clearfix green ">
                        <div class="box-tabs-container clearfix">
                            <h2>Reccomended Rooms</h2>
                            <ul class="box-tabs"></ul>
                        </div>
                        <div id="rooms-habblet-list-container-h105" class="recommendedrooms-lite-habblet-list-container">
                            <ul class="habblet-list">
                            {% for room in recommendedRooms %}
                                <li class="{% if loop.index is even %}odd{% else %}even{% endif %}">
                                    <span class="clearfix enter-room-link {{ room.occupancyClass }}" title="Go to room">
                                        <span class="room-enter">Enter</span>
                                        <span class="room-name">{{ room.name }}</span>
                                        <span class="room-description">{{ room.description }}</span>
                                        <span class="room-owner">Owner: <a href="{{ site.sitePath }}/community">{{ room.owner }}</a></span>
                                    </span>
                                </li>
                            {% endfor %}
                            </ul>
                            <div class="clearfix"></div>
                        </div>
                    </div>
                </div>
                <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>

                <div class="habblet-container ">
                    <div class="cbb clearfix activehomes ">
                        <h2 class="title">Random {{ site.pluralName }} - Click Us!</h2>
                        <div id="homes-habblet-list-container" class="habblet-list-container">
                            <ul class="habblet-list two-cols clearfix">
                            {% for member in activeMembers %}
                                <li class="{% if loop.index is even %}even right{% else %}odd left{% endif %}">
                                    <div class="item" style="min-height: 74px;">
                                        <img src="{{ site.sitePath }}/habbo-imaging/avatarimage?figure={{ member.figure }}&size=b&direction=4&head_direction=4&gesture=sml" alt="{{ member.name }}" width="54" height="70" style="float:left; margin-right:8px;" />
                                        <a class="item" href="{{ member.url }}">{{ member.name }}</a>
                                        <div class="article-meta">{{ member.createdOn }}</div>
                                        <p class="summary">{{ member.motto }}</p>
                                    </div>
                                </li>
                            {% endfor %}
                            </ul>
                        </div>
                    </div>
                </div>
                <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>
            </div>

            <div id="column2" class="column">
                <div class="habblet-container news-promo">
                    <div class="cbb clearfix notitle ">
                        <div id="newspromo">
                            <div id="topstories">
                                <div class="topstory" style="background-image: url({{ site.webGalleryPath }}/v2/images/landing/uk_party_frontpage_image.gif)">
                                    <h4>Latest news</h4>
                                    <h3><a href="{{ topStory.url }}">{{ topStory.title }}</a></h3>
                                    <p class="summary">{{ topStory.summary }}</p>
                                    <p><a href="{{ topStory.url }}">Read more &raquo;</a></p>
                                </div>
                            </div>
                            <ul class="widelist">
                            {% for headline in headlineStories %}
                                <li class="{% if loop.index is even %}odd{% else %}even{% endif %}">
                                    <a href="{{ headline.url }}">{{ headline.title }}</a><div class="newsitem-date">{{ headline.publishedAt }}</div>
                                </li>
                            {% endfor %}
                                <li class="last"><a href="{{ site.sitePath }}/news">More news &raquo;</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
                <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>

                <div class="habblet-container ">
                    <div class="cbb clearfix red ">
                        <h2 class="title">Users like..</h2>
                        <div class="habblet box-content">
                            <ul class="tag-list make-clickable">
                            {% for tag in tagCloud %}
                                <li><a href="{{ site.sitePath }}/tag" class="tag">{{ tag }}</a></li>
                            {% endfor %}
                            </ul>
                            <div class="tag-search-form">
                                <form action="{{ site.sitePath }}/tag" class="search-box">
                                    <input type="text" name="tag" id="search_query" value="" class="search-box-query" style="float: left"/>
                                    <a href="#" class="new-button search-icon" style="float: left"><b><span></span></b><i></i></a>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="column3" class="column">
                <div class="habblet-container ">
                    <div class="ad-container">
                        {% include "base/ads_container.peb" %}
                    </div>
                </div>
                <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>
            </div>
        </div>

{% include "base/footer.peb" %}

<script type="text/javascript">
HabboView.run();
</script>
</body>
</html>

