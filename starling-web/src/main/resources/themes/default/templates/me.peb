<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN"
        "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
<head>
    <meta http-equiv="content-type" content="text/html" />
    <title>{{ site.siteName }}: {{ currentUser.name }}</title>

<script type="text/javascript">
var andSoItBegins = (new Date()).getTime();
</script>
    <link rel="shortcut icon" href="{{ site.webGalleryPath }}/v2/favicon.ico" type="image/vnd.microsoft.icon" />
    <link rel="alternate" type="application/rss+xml" title="{{ site.siteName }}: RSS" href="{{ site.sitePath }}/articles/rss.xml" />
<script src="{{ site.webGalleryPath }}/static/js/libs2.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/visual.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/libs.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/common.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/fullcontent.js" type="text/javascript"></script>
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/style.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/buttons.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/boxes.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/tooltips.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/styles/local/com.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/styles/local/me.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/personal.css" type="text/css" />
<script src="{{ site.webGalleryPath }}/js/local/com.js" type="text/javascript"></script>

<script type="text/javascript">
document.habboLoggedIn = true;
var habboName = "{{ currentUser.name }}";
var ad_keywords = "";
var habboReqPath = "{{ site.sitePath }}";
var habboStaticFilePath = "{{ site.webGalleryPath }}";
var habboImagerUrl = "{{ site.habboImagingPath }}/";
var habboPartner = "";
window.name = "habboMain";
if (typeof HabboClient != "undefined") { HabboClient.windowName = "client"; }
</script>

    <meta name="description" content="{{ currentUser.name }}'s {{ site.siteName }} home." />
<meta name="keywords" content="{{ site.siteName }}, me, profile, community, groups, rooms" />
<meta name="build" content="HavanaWeb" />
</head>
<body id="home" class=" ">

{% include "base/header.peb" %}

<div id="content-container">
    {% include "base/subnav.peb" %}

<div id="container">
    <div id="content">
        <div id="column1" class="column">
            <div class="habblet-container ">
                <div id="new-personal-info" style="background-image:url({{ site.webGalleryPath }}/v2/images/personal_info/hotel_views/htlview_br.png)" >

    {% if site.serverOnline %}
    <div class="enter-hotel-btn">
        <div class="open enter-btn">
            <a href="{{ site.sitePath }}/client" target="client">Enter {{ site.siteName }}<i></i></a>
            <b></b>
        </div>
    </div>
    {% else %}
    <div class="enter-hotel-btn">
        <div class="closed enter-btn">
            <span>{{ site.siteName }} is offline</span>
            <b></b>
        </div>
    </div>
    {% endif %}

    <div id="habbo-plate">
        <a href="{{ site.sitePath }}/profile">
            <img alt="{{ currentUser.name }}" src="{{ site.sitePath }}/habbo-imaging/avatarimage?figure={{ currentUser.figure }}&size=b&direction=3&head_direction=3&crr=0&gesture=sml&frame=1" width="64" height="110" />
        </a>
    </div>

    <div id="habbo-info">
        <div id="motto-container" class="clearfix">
            <strong>{{ currentUser.name }}:</strong>
            <div>
                <span title="Click to enter your motto/ status">{% if currentUser.motto != "" %}{{ currentUser.motto }}{% else %}Click here to enter your motto{% endif %}</span>
            </div>
        </div>
    </div>

    <ul id="link-bar" class="clearfix">
        <li class="change-looks"><a href="{{ site.sitePath }}/profile">Change looks &raquo;</a></li>
        <li class="credits">
            <a href="{{ site.sitePath }}/credits">{{ currentUser.credits }}</a> credits
        </li>
        <li class="club">
            {% if currentUser.clubActive %}
            <a href="{{ site.sitePath }}/club">{{ currentUser.clubDays }}</a> HC days
            {% else %}
            <a href="{{ site.sitePath }}/club">Join {{ site.siteName }} club &raquo;</a>
            {% endif %}
        </li>
    </ul>

    <div id="habbo-feed">
        <ul id="feed-items">
            <li class="small" id="feed-friends">
                You have {{ onlineFriends | length }} friends online
                <span>
                {% for friend in onlineFriends %}
                    <a href="{{ site.sitePath }}/home/{{ friend }}">{{ friend }}</a>{% if not loop.last %}, {% endif %}
                {% endfor %}
                </span>
            </li>
            <li class="small" id="feed-lastlogin">
                Last signed in:
                {{ currentUser.lastOnline }}
            </li>
            <li class="small" id="feed-member-since">
                Member since:
                {{ currentUser.memberSince }}
            </li>
        </ul>
    </div>

    <p class="last"></p>
</div>
            </div>
            <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>

            <div class="habblet-container ">
                <div class="cbb clearfix orange ">
                    <h2 class="title">Hot Campaigns</h2>
                    <div id="hotcampaigns-habblet-list-container">
                        {% if hotCampaigns | length > 0 %}
                        <ul id="hotcampaigns-habblet-list">
                        {% for campaign in hotCampaigns %}
                            <li class="{% if loop.index is even %}even{% else %}odd{% endif %}{% if loop.last %} last{% endif %}">
                                <div class="hotcampaign-container">
                                    <a href="{{ campaign.url }}"><img src="{{ campaign.imageUrl }}" alt="{{ campaign.name }}" /></a>
                                    <h3>{{ campaign.name }}</h3>
                                    <p>{{ campaign.description }}</p>
                                    <p class="link"><a href="{{ campaign.url }}">Go there &raquo;</a></p>
                                </div>
                            </li>
                        {% endfor %}
                        </ul>
                        {% else %}
                        <p class="hotcampaigns-empty">No campaigns are live right now. Check back soon.</p>
                        {% endif %}
                    </div>
                </div>
            </div>
            <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>

            <div class="habblet-container minimail" id="mail">
                <div class="cbb clearfix blue ">
                    <h2 class="title">My Messages</h2>
                    <div id="minimail">
                        {% if minimail.notice != "" %}
                        <div class="minimail-flash minimail-notice">{{ minimail.notice }}</div>
                        {% endif %}
                        {% if minimail.error != "" %}
                        <div class="minimail-flash minimail-error">{{ minimail.error }}</div>
                        {% endif %}

                        <div class="minimail-toolbar clearfix">
                            <a href="{{ site.sitePath }}/me?mailbox={{ minimail.label }}&compose=true{% if minimail.unreadOnly %}&unreadOnly=true{% endif %}" class="new-button compose"><b>Compose</b><i></i></a>
                            <div class="clearfix labels nostandard">
                                <ul class="box-tabs">
                                    <li{% if minimail.label == "inbox" %} class="selected"{% endif %}><a href="{{ site.sitePath }}/me?mailbox=inbox">Inbox{% if minimail.unreadCount > 0 %} ({{ minimail.unreadCount }}){% endif %}</a><span class="tab-spacer"></span></li>
                                    <li{% if minimail.label == "sent" %} class="selected"{% endif %}><a href="{{ site.sitePath }}/me?mailbox=sent">Sent</a><span class="tab-spacer"></span></li>
                                    <li{% if minimail.label == "trash" %} class="selected"{% endif %}><a href="{{ site.sitePath }}/me?mailbox=trash">Trash</a><span class="tab-spacer"></span></li>
                                </ul>
                            </div>
                        </div>

                        {% if minimail.composeMode %}
                        <form method="post" action="{{ site.sitePath }}/me/minimail/compose" class="minimail-compose-form">
                            <label for="minimail-recipients">To</label>
                            <input id="minimail-recipients" type="text" name="recipients" value="{{ minimail.composeRecipients }}" maxlength="255" />
                            <p class="minimail-help">Separate multiple usernames with commas.</p>

                            <label for="minimail-subject">Subject</label>
                            <input id="minimail-subject" type="text" name="subject" value="{{ minimail.composeSubject }}" maxlength="100" />

                            <label for="minimail-body">Message</label>
                            <textarea id="minimail-body" name="body" rows="5" cols="10">{{ minimail.composeBody }}</textarea>

                            <div class="minimail-form-actions">
                                <button type="submit" class="minimail-button">Send Message</button>
                                <a href="{{ site.sitePath }}/me?mailbox={{ minimail.label }}{% if minimail.unreadOnly %}&unreadOnly=true{% endif %}" class="minimail-cancel">Cancel</a>
                            </div>
                        </form>
                        {% endif %}

                        {% if minimail.label == "inbox" %}
                        <form method="get" action="{{ site.sitePath }}/me" class="minimail-filter-form">
                            <input type="hidden" name="mailbox" value="inbox" />
                            <label><input type="checkbox" name="unreadOnly" value="true"{% if minimail.unreadOnly %} checked="checked"{% endif %} /> Only unread</label>
                            <button type="submit" class="minimail-link-button">Apply</button>
                        </form>
                        {% elseif minimail.label == "trash" %}
                        <form method="post" action="{{ site.sitePath }}/me/minimail/trash/empty" class="minimail-trash-form">
                            <p>Messages moved to trash stay here until you empty it.</p>
                            <button type="submit" class="minimail-link-button">Empty trash</button>
                        </form>
                        {% endif %}

                        {% if minimail.totalMessages > 0 %}
                        <div class="minimail-pagination">
                            <span>{{ minimail.startIndex }} - {{ minimail.endIndex }} of {{ minimail.totalMessages }}</span>
                            {% if minimail.hasNewerPage %}
                            <a href="{{ site.sitePath }}/me?mailbox={{ minimail.label }}&mailPage={{ minimail.newerPage }}{% if minimail.unreadOnly %}&unreadOnly=true{% endif %}" class="minimail-page-link">Newer</a>
                            {% endif %}
                            {% if minimail.hasOlderPage %}
                            <a href="{{ site.sitePath }}/me?mailbox={{ minimail.label }}&mailPage={{ minimail.olderPage }}{% if minimail.unreadOnly %}&unreadOnly=true{% endif %}" class="minimail-page-link">Older</a>
                            {% endif %}
                        </div>
                        {% endif %}

                        <div class="minimail-list">
                            {% if minimail.messages | length > 0 %}
                            {% for message in minimail.messages %}
                            <a href="{{ site.sitePath }}/me?mailbox={{ minimail.label }}&messageId={{ message.id }}{% if minimail.unreadOnly %}&unreadOnly=true{% endif %}{% if minimail.currentPage > 1 %}&mailPage={{ minimail.currentPage }}{% endif %}" class="minimail-preview {{ message.statusClass }}{% if minimail.selectedMessageId == message.id %} selected{% endif %}">
                                <img src="{{ message.avatarUrl }}" alt="{{ message.senderName }}" />
                                <span class="minimail-preview-meta">
                                    <span class="minimail-preview-date">{{ message.sentAt }}</span>
                                    {% if minimail.label == "sent" %}
                                    <span class="minimail-preview-name">To: {{ message.recipientName }}</span>
                                    {% else %}
                                    <span class="minimail-preview-name">{{ message.senderName }}</span>
                                    {% endif %}
                                    <span class="minimail-preview-subject">&ldquo;{{ message.subject }}&rdquo;</span>
                                </span>
                            </a>
                            {% endfor %}
                            {% else %}
                            <p class="minimail-empty">{{ minimail.emptyMessage }}</p>
                            {% endif %}
                        </div>

                        {% if minimail.selectedMessage %}
                        <div class="minimail-detail">
                            <div class="minimail-detail-head">
                                <img src="{{ minimail.selectedMessage.senderAvatarUrl }}" alt="{{ minimail.selectedMessage.senderName }}" />
                                <div class="minimail-detail-copy">
                                    <h3>{{ minimail.selectedMessage.subject }}</h3>
                                    <p><strong>From:</strong> {{ minimail.selectedMessage.senderName }}</p>
                                    <p><strong>To:</strong> {{ minimail.selectedMessage.recipientName }}</p>
                                    <p><strong>Sent:</strong> {{ minimail.selectedMessage.sentAt }}</p>
                                </div>
                            </div>
                            <div class="minimail-detail-body">{{ minimail.selectedMessage.bodyHtml | raw }}</div>

                            <div class="minimail-detail-actions">
                                {% if minimail.label == "trash" %}
                                <form method="post" action="{{ site.sitePath }}/me/minimail/{{ minimail.selectedMessage.id }}/restore">
                                    <button type="submit" class="minimail-button">Restore</button>
                                </form>
                                <form method="post" action="{{ site.sitePath }}/me/minimail/{{ minimail.selectedMessage.id }}/delete">
                                    <input type="hidden" name="mailbox" value="trash" />
                                    <input type="hidden" name="mailPage" value="{{ minimail.currentPage }}" />
                                    <button type="submit" class="minimail-button minimail-button-danger">Delete Permanently</button>
                                </form>
                                {% elseif minimail.label == "inbox" %}
                                <form method="post" action="{{ site.sitePath }}/me/minimail/{{ minimail.selectedMessage.id }}/delete">
                                    <input type="hidden" name="mailbox" value="inbox" />
                                    <input type="hidden" name="mailPage" value="{{ minimail.currentPage }}" />
                                    {% if minimail.unreadOnly %}
                                    <input type="hidden" name="unreadOnly" value="true" />
                                    {% endif %}
                                    <button type="submit" class="minimail-button minimail-button-danger">Move To Trash</button>
                                </form>
                                {% if minimail.selectedMessage.replyable %}
                                <a href="{{ site.sitePath }}/me?mailbox=inbox&messageId={{ minimail.selectedMessage.id }}&reply=true{% if minimail.unreadOnly %}&unreadOnly=true{% endif %}{% if minimail.currentPage > 1 %}&mailPage={{ minimail.currentPage }}{% endif %}" class="minimail-cancel minimail-inline-link">Reply</a>
                                {% endif %}
                                {% endif %}
                            </div>

                            {% if minimail.replyMode %}
                            <form method="post" action="{{ site.sitePath }}/me/minimail/{{ minimail.selectedMessage.id }}/reply" class="minimail-reply-form">
                                <label for="minimail-reply-body">Reply</label>
                                <textarea id="minimail-reply-body" name="body" rows="5" cols="10">{{ minimail.composeBody }}</textarea>
                                <div class="minimail-form-actions">
                                    <button type="submit" class="minimail-button">Send Reply</button>
                                    <a href="{{ site.sitePath }}/me?mailbox=inbox&messageId={{ minimail.selectedMessage.id }}{% if minimail.unreadOnly %}&unreadOnly=true{% endif %}{% if minimail.currentPage > 1 %}&mailPage={{ minimail.currentPage }}{% endif %}" class="minimail-cancel">Cancel</a>
                                </div>
                            </form>
                            {% endif %}
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>
        </div>

        <div id="column2" class="column">
            <div class="habblet-container news-promo">
                <div class="cbb clearfix notitle ">
                    <div id="newspromo">
                        <div id="topstories">
                            <div class="topstory" style="background-image: url({{ site.webGalleryPath }}/v2/images/landing/uk_party_frontpage_image.gif)">
                                <h4>Latest news</h4>
                                <h3><a href="{{ article1.url }}">{{ article1.title }}</a></h3>
                                <p class="summary">{{ article1.summary }}</p>
                                <p><a href="{{ article1.url }}">Read more &raquo;</a></p>
                            </div>
                        </div>
                        <ul class="widelist">
                            <li class="even">
                                <a href="{{ article2.url }}">{{ article2.title }}</a><div class="newsitem-date">{{ article2.publishedAt }}</div>
                            </li>
                            <li class="odd">
                                <a href="{{ article3.url }}">{{ article3.title }}</a><div class="newsitem-date">{{ article3.publishedAt }}</div>
                            </li>
                            <li class="even">
                                <a href="{{ article4.url }}">{{ article4.title }}</a><div class="newsitem-date">{{ article4.publishedAt }}</div>
                            </li>
                            <li class="odd">
                                <a href="{{ article5.url }}">{{ article5.title }}</a><div class="newsitem-date">{{ article5.publishedAt }}</div>
                            </li>
                            <li class="last"><a href="{{ site.sitePath }}/news">More news &raquo;</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>

            <div class="habblet-container ">
                <div class="cbb clearfix green ">
                    <div class="box-tabs-container clearfix">
                        <h2>Tags</h2>
                        <ul class="box-tabs">
                            <li class="selected"><a href="#">My Tags</a><span class="tab-spacer"></span></li>
                        </ul>
                    </div>
                    <div id="my-tag-info" class="habblet-content-info">
                        {% if tagCloud | length > 0 %}
                        You have not used up all your tags yet - add some more!
                        {% else %}
                        You have not set any tags yet.
                        {% endif %}
                    </div>
                    <div class="box-content">
                        {% if tagCloud | length > 0 %}
                        <ul class="tag-list make-clickable">
                        {% for tag in tagCloud %}
                            <li><a href="{{ site.sitePath }}/tag" class="tag">{{ tag }}</a></li>
                        {% endfor %}
                        </ul>
                        {% else %}
                        <p class="tag-habblet-empty">You have not set any tags yet.</p>
                        {% endif %}
                    </div>
                </div>
            </div>
            <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>
        </div>

        <div id="column3" class="column">
            <div class="habblet-container ">
                <div class="ad-container">
                    {% include "base/ads_container.peb" %}
                </div>
            </div>
            <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>
        </div>
    </div>
    </div>
{% include "base/footer.peb" %}

<script type="text/javascript">
HabboView.run();
</script>
</body>
</html>

