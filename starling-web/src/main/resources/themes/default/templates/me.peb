<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN"
        "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
<head>
    <meta http-equiv="content-type" content="text/html" />
    <title>{{ site.siteName }}: {{ currentUser.name }}</title>

<script type="text/javascript">
var andSoItBegins = (new Date()).getTime();
</script>
    <link rel="shortcut icon" href="{{ site.staticContentPath }}/web-gallery/v2/favicon.ico" type="image/vnd.microsoft.icon" />
    <link rel="alternate" type="application/rss+xml" title="{{ site.siteName }}: RSS" href="{{ site.sitePath }}/articles/rss.xml" />
<script src="{{ site.staticContentPath }}/web-gallery/static/js/libs2.js" type="text/javascript"></script>
<script src="{{ site.staticContentPath }}/web-gallery/static/js/visual.js" type="text/javascript"></script>
<script src="{{ site.staticContentPath }}/web-gallery/static/js/libs.js" type="text/javascript"></script>
<script src="{{ site.staticContentPath }}/web-gallery/static/js/common.js" type="text/javascript"></script>
<script src="{{ site.staticContentPath }}/web-gallery/static/js/fullcontent.js" type="text/javascript"></script>
<link rel="stylesheet" href="{{ site.staticContentPath }}/web-gallery/v2/styles/style.css" type="text/css" />
<link rel="stylesheet" href="{{ site.staticContentPath }}/web-gallery/v2/styles/buttons.css" type="text/css" />
<link rel="stylesheet" href="{{ site.staticContentPath }}/web-gallery/v2/styles/boxes.css" type="text/css" />
<link rel="stylesheet" href="{{ site.staticContentPath }}/web-gallery/v2/styles/tooltips.css" type="text/css" />
<link rel="stylesheet" href="{{ site.staticContentPath }}/web-gallery/styles/local/com.css" type="text/css" />
<link rel="stylesheet" href="{{ site.staticContentPath }}/web-gallery/v2/styles/personal.css" type="text/css" />
<script src="{{ site.staticContentPath }}/web-gallery/js/local/com.js" type="text/javascript"></script>

<script type="text/javascript">
document.habboLoggedIn = true;
var habboName = "{{ currentUser.name }}";
var ad_keywords = "";
var habboReqPath = "{{ site.sitePath }}";
var habboStaticFilePath = "{{ site.staticContentPath }}/web-gallery";
var habboImagerUrl = "{{ site.staticContentPath }}/habbo-imaging/";
var habboPartner = "";
window.name = "habboMain";
if (typeof HabboClient != "undefined") { HabboClient.windowName = "client"; }
</script>

<meta name="description" content="{{ currentUser.name }}'s Starling home." />
<meta name="keywords" content="{{ site.siteName }}, me, profile, community, groups, rooms" />
<meta name="build" content="HavanaWeb" />
</head>
<body id="home" class=" ">

{% include "base/header.peb" %}

<div id="content-container">
    <div id="navi2-container" class="pngbg">
        <div id="navi2" class="pngbg clearfix">
            <ul>
                <li class="selected">
                    Home
                </li>
                <li class="">
                    <a href="{{ site.sitePath }}/home/{{ currentUser.name }}">My Page</a>
                </li>
                <li class="">
                    <a href="{{ site.sitePath }}/profile">Account Settings</a>
                </li>
                <li class="">
                    <a href="{{ site.sitePath }}/club">{{ site.siteName }} Club</a>
                </li>
                <li class=" last">
                    <a href="{{ site.sitePath }}/community">Community</a>
                </li>
            </ul>
        </div>
    </div>

<div id="container">
    <div id="content">
        <div id="column1" class="column">
            <div class="habblet-container ">
                <div id="new-personal-info" style="background-image:url({{ site.staticContentPath }}/web-gallery/v2/images/personal_info/hotel_views/htlview_br.png)" >

    {% if site.serverOnline %}
    <div class="enter-hotel-btn">
        <div class="open enter-btn">
            <a href="{{ site.sitePath }}/client" target="client">Enter {{ site.siteName }}<i></i></a>
            <b></b>
        </div>
    </div>
    {% else %}
    <div class="enter-hotel-btn">
        <div class="closed enter-btn">
            <span>{{ site.siteName }} is offline</span>
            <b></b>
        </div>
    </div>
    {% endif %}

    <div id="habbo-plate">
        <a href="{{ site.sitePath }}/profile">
            <img alt="{{ currentUser.name }}" src="{{ site.sitePath }}/habbo-imaging/avatarimage?figure={{ currentUser.figure }}&size=b&direction=3&head_direction=3&crr=0&gesture=sml&frame=1" width="64" height="110" />
        </a>
    </div>

    <div id="habbo-info">
        <div id="motto-container" class="clearfix">
            <strong>{{ currentUser.name }}:</strong>
            <div>
                <span title="Click to enter your motto/ status">{% if currentUser.motto != "" %}{{ currentUser.motto }}{% else %}Click here to enter your motto{% endif %}</span>
            </div>
        </div>
    </div>

    <ul id="link-bar" class="clearfix">
        <li class="change-looks"><a href="{{ site.sitePath }}/profile">Change looks &raquo;</a></li>
        <li class="credits">
            <a href="{{ site.sitePath }}/credits">{{ currentUser.credits }}</a> credits
        </li>
        <li class="club">
            {% if currentUser.clubActive %}
            <a href="{{ site.sitePath }}/club">{{ currentUser.clubDays }}</a> HC days
            {% else %}
            <a href="{{ site.sitePath }}/club">Join {{ site.siteName }} club &raquo;</a>
            {% endif %}
        </li>
    </ul>

    <div id="habbo-feed">
        <ul id="feed-items">
            <li class="small" id="feed-friends">
                You have {{ onlineFriends | length }} friends online
                <span>
                {% for friend in onlineFriends %}
                    <a href="{{ site.sitePath }}/home/{{ friend }}">{{ friend }}</a>{% if not loop.last %}, {% endif %}
                {% endfor %}
                </span>
            </li>
            <li class="small" id="feed-lastlogin">
                Last signed in:
                {{ currentUser.lastOnline }}
            </li>
            <li class="small" id="feed-member-since">
                Member since:
                {{ currentUser.memberSince }}
            </li>
        </ul>
    </div>

    <p class="last"></p>
</div>
            </div>
            <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>

            <div class="habblet-container ">
                <div class="cbb clearfix blue ">
                    <div class="box-tabs-container clearfix">
                        <h2>Groups</h2>
                        <ul class="box-tabs">
                            <li class="selected"><a href="#">My Groups</a><span class="tab-spacer"></span></li>
                        </ul>
                    </div>
                    <div id="groups-habblet-info" class="habblet-content-info">
                        View the groups you are in, create your own group, or get some inspiration from the community.
                    </div>
                    <div id="groups-habblet-list-container" class="habblet-list-container groups-list">
                        <ul class="habblet-list two-cols clearfix">
                        {% for group in recommendedGroups %}
                            <li class="{% if loop.index is even %}even right{% else %}odd left{% endif %}">
                                <a class="item" href="{{ site.sitePath }}/community">{{ group.name }}</a>
                            </li>
                        {% endfor %}
                        </ul>
                    </div>
                    <div class="habblet-button-row clearfix"><a class="new-button" href="{{ site.sitePath }}/community"><b>Browse Groups</b><i></i></a></div>
                </div>
            </div>
            <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>

            <div class="habblet-container ">
                <div class="cbb clearfix green ">
                    <div class="box-tabs-container clearfix">
                        <h2>Tags</h2>
                        <ul class="box-tabs">
                            <li class="selected"><a href="#">My Tags</a><span class="tab-spacer"></span></li>
                        </ul>
                    </div>
                    <div id="my-tag-info" class="habblet-content-info">
                        You have not used up all your tags yet - add some more!
                    </div>
                    <div class="box-content">
                        <ul class="tag-list make-clickable">
                        {% for tag in tagCloud %}
                            <li><a href="{{ site.sitePath }}/tag" class="tag">{{ tag }}</a></li>
                        {% endfor %}
                        </ul>
                    </div>
                </div>
            </div>
            <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>
        </div>

        <div id="column2" class="column">
            <div class="habblet-container news-promo">
                <div class="cbb clearfix notitle ">
                    <div id="newspromo">
                        <div id="topstories">
                            <div class="topstory" style="background-image: url({{ site.staticContentPath }}/web-gallery/v2/images/landing/uk_party_frontpage_image.gif)">
                                <h4>Latest news</h4>
                                <h3><a href="{{ article1.url }}">{{ article1.title }}</a></h3>
                                <p class="summary">{{ article1.summary }}</p>
                                <p><a href="{{ article1.url }}">Read more &raquo;</a></p>
                            </div>
                        </div>
                        <ul class="widelist">
                            <li class="even">
                                <a href="{{ article2.url }}">{{ article2.title }}</a><div class="newsitem-date">{{ article2.publishedAt }}</div>
                            </li>
                            <li class="odd">
                                <a href="{{ article3.url }}">{{ article3.title }}</a><div class="newsitem-date">{{ article3.publishedAt }}</div>
                            </li>
                            <li class="even">
                                <a href="{{ article4.url }}">{{ article4.title }}</a><div class="newsitem-date">{{ article4.publishedAt }}</div>
                            </li>
                            <li class="odd">
                                <a href="{{ article5.url }}">{{ article5.title }}</a><div class="newsitem-date">{{ article5.publishedAt }}</div>
                            </li>
                            <li class="last"><a href="{{ site.sitePath }}/news">More news &raquo;</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>

            <div class="habblet-container ">
                <div class="cbb clearfix green ">
                    <div class="box-tabs-container clearfix">
                        <h2>Reccomended Rooms</h2>
                        <ul class="box-tabs"></ul>
                    </div>
                    <div id="rooms-habblet-list-container-h105" class="recommendedrooms-lite-habblet-list-container">
                        <ul class="habblet-list">
                        {% for room in recommendedRooms %}
                            <li class="{% if loop.index is even %}odd{% else %}even{% endif %}">
                                <span class="clearfix enter-room-link {{ room.occupancyClass }}" title="Go to room">
                                    <span class="room-enter">Enter</span>
                                    <span class="room-name">{{ room.name }}</span>
                                    <span class="room-description">{{ room.description }}</span>
                                    <span class="room-owner">Owner: <a href="{{ site.sitePath }}/community">{{ room.owner }}</a></span>
                                </span>
                            </li>
                        {% endfor %}
                        </ul>
                        <div class="clearfix"></div>
                    </div>
                </div>
            </div>
            <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>
        </div>

        <div id="column3" class="column">
            <div class="habblet-container ">
                <div class="ad-container">
                    {% include "base/ads_container.peb" %}
                </div>
            </div>
            <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>
        </div>
    </div>
    </div>
{% include "base/footer.peb" %}

<script type="text/javascript">
HabboView.run();
</script>
</body>
</html>
