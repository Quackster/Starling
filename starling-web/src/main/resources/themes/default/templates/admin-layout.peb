<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ siteTitle }}</title>
    <link rel="stylesheet" href="/assets/admin.css">
    <script src="https://unpkg.com/htmx.org@1.9.12"></script>
</head>
<body class="admin-shell{% if isLoginPage %} admin-shell--login{% endif %}">
{% if isLoginPage %}
    <div class="hk-login-shell">
        <main class="hk-login-shell__main">
            {{ bodyHtml | raw }}
        </main>
        <footer class="hk-footer">
            {{ cmsTitle }} housekeeping inspired by Quackster &copy; {{ year }}
        </footer>
    </div>
{% else %}
    <div class="hk-topbar">
        <span>Logged in as: <strong>{{ currentAdminName }}</strong> in {{ cmsTitle }}</span>
        <a href="/">Secure Login to {{ siteName }}</a>
    </div>

    <nav class="hk-tabs" aria-label="Housekeeping sections">
        <a class="hk-tab{% if currentPath == '/admin' %} is-active{% endif %}" href="/admin">Dashboard</a>
        <a
                class="hk-tab{% if currentPath == '/admin/pages' or currentPath == '/admin/navigation' or currentPath == '/admin/articles' or currentPath == '/admin/campaigns' %} is-active{% endif %}"
                href="{% if canManagePages %}/admin/pages{% elseif canManageNavigation %}/admin/navigation{% elseif canManageArticles %}/admin/articles{% elseif canManageCampaigns %}/admin/campaigns{% else %}/admin{% endif %}"
        >Content</a>
        <a
                class="hk-tab{% if currentPath == '/admin/users' or currentPath == '/admin/permissions' %} is-active{% endif %}"
                href="{% if canManageUsers %}/admin/users{% elseif canManagePermissions %}/admin/permissions{% else %}/admin{% endif %}"
        >Staff</a>
        <a class="hk-tab" href="/">Hotel</a>
    </nav>

    {% if notice or error %}
        <section class="hk-alerts">
            {% if notice %}
                <div class="flash flash--success flash--retro">
                    <span>{{ notice }}</span>
                    <button type="button" class="flash__close" aria-label="Dismiss notice">&times;</button>
                </div>
            {% endif %}
            {% if error %}
                <div class="flash flash--error flash--retro">
                    <span>{{ error }}</span>
                    <button type="button" class="flash__close" aria-label="Dismiss error">&times;</button>
                </div>
            {% endif %}
        </section>
    {% endif %}

    <div class="hk-frame">
        <aside class="hk-sidebar">
            <section class="hk-sidebar-box">
                <h2>Content tools</h2>
                <ul>
                    <li><a{% if currentPath == '/admin' %} class="is-active"{% endif %} href="/admin">Dashboard</a></li>
                    {% if canManagePages %}<li><a{% if currentPath == '/admin/pages' %} class="is-active"{% endif %} href="/admin/pages">Pages</a></li>{% endif %}
                    {% if canManageNavigation %}<li><a{% if currentPath == '/admin/navigation' %} class="is-active"{% endif %} href="/admin/navigation">Navigation</a></li>{% endif %}
                    {% if canManageArticles %}<li><a{% if currentPath == '/admin/articles' %} class="is-active"{% endif %} href="/admin/articles">News</a></li>{% endif %}
                    {% if canManageCampaigns %}<li><a{% if currentPath == '/admin/campaigns' %} class="is-active"{% endif %} href="/admin/campaigns">Campaigns</a></li>{% endif %}
                </ul>
            </section>

            <section class="hk-sidebar-box">
                <h2>Staff tools</h2>
                <ul>
                    {% if canManageUsers %}<li><a{% if currentPath == '/admin/users' %} class="is-active"{% endif %} href="/admin/users">Users</a></li>{% endif %}
                    {% if canManagePermissions %}<li><a{% if currentPath == '/admin/permissions' %} class="is-active"{% endif %} href="/admin/permissions">Permissions</a></li>{% endif %}
                    <li><a href="/">View site</a></li>
                </ul>
            </section>

            <section class="hk-sidebar-box hk-sidebar-box--muted">
                <h2>Session</h2>
                <div class="hk-timebox">
                    <strong>Local time:</strong>
                    <div id="hk-local-date">Loading...</div>
                    <div id="hk-local-time">Loading...</div>
                </div>
                <div class="hk-timebox">
                    <strong>Server:</strong>
                    <div>{{ cmsTitle }}</div>
                    <div>{{ currentAdminName }}</div>
                </div>
                <form method="post" action="/admin/logout" class="hk-sidebar-form">
                    <button class="hk-plain-button" type="submit">Log out</button>
                </form>
            </section>
        </aside>

        <main class="hk-content">
            {{ bodyHtml | raw }}
        </main>
    </div>

    <footer class="hk-footer">
        {{ cmsTitle }} housekeeping inspired by Quackster &copy; {{ year }}
    </footer>
{% endif %}

<script>
document.querySelectorAll(".flash__close").forEach(function (button) {
    button.addEventListener("click", function () {
        var flash = button.closest(".flash");
        if (flash) {
            flash.style.display = "none";
        }
    });
});

var localDate = document.getElementById("hk-local-date");
var localTime = document.getElementById("hk-local-time");
if (localDate && localTime) {
    var now = new Date();
    localDate.textContent = now.toLocaleDateString(undefined, {
        year: "numeric",
        month: "long",
        day: "numeric"
    });
    localTime.textContent = now.toLocaleTimeString();
}
</script>
</body>
</html>
