<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ siteTitle }}</title>
    {% if isLoginPage %}
        <link rel="stylesheet" href="/assets/admin-login.css">
    {% else %}
        <link rel="stylesheet" href="/assets/admin.css">
        <link rel="stylesheet" href="/assets/admin-components.css">
    {% endif %}
    <script src="https://unpkg.com/htmx.org@1.9.12"></script>
</head>
<body class="admin-shell{% if isLoginPage %} admin-shell--login{% endif %}">
{% if isLoginPage %}
    <div class="wrapper">
        <div class="content">
            <div class="container">
                {{ bodyHtml | raw }}
            </div>
        </div>

        <div class="footer">
            theallseeingeye by Quackster &copy; Copyright 2025
        </div>
    </div>
{% else %}
    <div class="topbar">
        Logged in as: <strong>{{ currentAdminName }}</strong>
        <a href="/">Secure Login to {{ siteName }}</a>
    </div>

    <div class="tabs">
        <a href="/admin" class="tab{% if currentPath == '/admin' %} active{% endif %}">Dashboard</a>
        {% if canManagePages %}
            <a href="/admin/pages" class="tab{% if currentPath == '/admin/pages' %} active{% endif %}">Pages</a>
        {% endif %}
        {% if canManageNavigation or canManageArticles or canManageUsers or canManagePermissions %}
            <a
                    href="{% if canManageNavigation %}/admin/navigation{% elseif canManageArticles %}/admin/articles{% elseif canManageUsers %}/admin/users{% elseif canManagePermissions %}/admin/permissions{% else %}/admin{% endif %}"
                    class="tab{% if currentPath == '/admin/navigation' or currentPath == '/admin/articles' or currentPath == '/admin/users' or currentPath == '/admin/permissions' %} active{% endif %}"
            >Admin tools</a>
        {% endif %}
        {% if canManageCampaigns %}
            <a href="/admin/campaigns" class="tab{% if currentPath == '/admin/campaigns' %} active{% endif %}">Campaign management</a>
        {% endif %}
    </div>

    {% if notice or error %}
        <div class="alerts-box">
            {% if notice %}
                <div class="message-box success">
                    {{ notice }}
                    <button class="close-btn" onclick="closeMessageBox(event)">&times;</button>
                </div>
            {% endif %}
            {% if error %}
                <div class="message-box error">
                    {{ error }}
                    <button class="close-btn" onclick="closeMessageBox(event)">&times;</button>
                </div>
            {% endif %}
        </div>
    {% endif %}

    <div class="container">
        <div class="sidebar">
            <div class="box">
                <p>Content tools</p>
                <ul>
                    <li><a href="/admin">Dashboard</a></li>
                    {% if canManagePages %}<li><a href="/admin/pages">Pages</a></li>{% endif %}
                    {% if canManageNavigation %}<li><a href="/admin/navigation">Navigation</a></li>{% endif %}
                    {% if canManageArticles %}<li><a href="/admin/articles">News</a></li>{% endif %}
                    {% if canManageCampaigns %}<li><a href="/admin/campaigns">Campaigns</a></li>{% endif %}
                </ul>
            </div>

            <div class="box">
                <p>Staff tools</p>
                <ul>
                    {% if canManageUsers %}<li><a href="/admin/users">Users</a></li>{% endif %}
                    {% if canManagePermissions %}<li><a href="/admin/permissions">Permissions</a></li>{% endif %}
                    <li><a href="/">Return to site</a></li>
                </ul>
            </div>

            <div class="box">
                <p>Session</p>
                <ul>
                    <li><strong>Admin:</strong> {{ currentAdminName }}</li>
                    <li><strong>Area:</strong> {{ cmsTitle }}</li>
                </ul>
                <form method="post" action="/admin/logout" class="sidebar-form">
                    <button type="submit" class="retro-button">Log out</button>
                </form>
            </div>

            <div class="time-panel">
                <strong>Local time:</strong><br>
                <span id="hk-local-date">Loading...</span><br>
                <span id="hk-local-time">Loading...</span><br><br>
                <strong>Server time:</strong><br>
                {{ cmsTitle }}<br>
                <span id="hk-server-date">Loading...</span><br>
                <span id="hk-server-time">Loading...</span>
            </div>
        </div>

        <div class="column1 hk-admin-content">
            {{ bodyHtml | raw }}
        </div>
    </div>

    <div class="footer">
        theallseeingeye by Quackster &copy; Copyright 2025
    </div>

    <script>
        function closeMessageBox(event) {
            event.target.closest('.message-box').style.display = 'none';
        }

        var now = new Date();
        var dateText = now.toLocaleDateString(undefined, {
            year: "numeric",
            month: "long",
            day: "numeric"
        });
        var timeText = now.toLocaleTimeString();
        document.getElementById("hk-local-date").textContent = dateText;
        document.getElementById("hk-local-time").textContent = timeText;
        document.getElementById("hk-server-date").textContent = dateText;
        document.getElementById("hk-server-time").textContent = timeText;
    </script>
{% endif %}
</body>
</html>
