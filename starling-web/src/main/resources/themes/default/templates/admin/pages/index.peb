<section class="admin-toolbar">
    <div>
        <h1>Pages</h1>
        <p>Manage long-form public content such as the homepage and evergreen site pages.</p>
    </div>
    <a class="button-primary" href="/admin/pages/new">New Page</a>
</section>

<section class="admin-card">
    <table class="data-table">
        <thead>
        <tr>
            <th>Title</th>
            <th>Slug</th>
            <th>Status</th>
            <th>Updated</th>
        </tr>
        </thead>
        <tbody>
        {% for page in pages %}
            <tr>
                <td><a href="/admin/pages/{{ page.id }}/edit">{{ page.title }}</a></td>
                <td>{{ page.slug }}</td>
                <td>{% if page.published %}Published{% else %}Draft{% endif %}</td>
                <td>{{ page.updatedAt }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">No pages yet.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</section>
