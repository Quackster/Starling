<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN"
        "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
<head>
    <meta http-equiv="content-type" content="text/html" />
    <title>{{ site.siteName }}: Tags</title>

<script type="text/javascript">
var andSoItBegins = (new Date()).getTime();
</script>
    <link rel="shortcut icon" href="{{ site.webGalleryPath }}/v2/favicon.ico" type="image/vnd.microsoft.icon" />
    <link rel="alternate" type="application/rss+xml" title="{{ site.siteName }}: RSS" href="{{ site.sitePath }}/articles/rss.xml" />
<script src="{{ site.webGalleryPath }}/static/js/libs2.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/visual.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/libs.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/common.js" type="text/javascript"></script>
<script src="{{ site.webGalleryPath }}/static/js/fullcontent.js" type="text/javascript"></script>
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/style.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/buttons.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/boxes.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/v2/styles/tooltips.css" type="text/css" />
<link rel="stylesheet" href="{{ site.webGalleryPath }}/styles/local/com.css" type="text/css" />

<script src="{{ site.webGalleryPath }}/js/local/com.js" type="text/javascript"></script>

<script type="text/javascript">
document.habboLoggedIn = {{ session.loggedIn }};
var habboName = {% if session.loggedIn %}"{{ playerDetails.name }}"{% else %}null{% endif %};
var ad_keywords = "";
var habboReqPath = "{{ site.sitePath }}";
var habboStaticFilePath = "{{ site.webGalleryPath }}";
var habboImagerUrl = "{{ site.habboImagingPath }}/";
var habboPartner = "";
window.name = "habboMain";
if (typeof HabboClient != "undefined") { HabboClient.windowName = "client"; }
</script>

<meta name="description" content="Browse tags and discover the community around {{ site.siteName }}." />
<meta name="keywords" content="{{ site.siteName }}, tags, community, groups, rooms" />
<meta name="build" content="Starling" />
</head>
{% if session.loggedIn == false %}
<body id="tags" class="anonymous ">
{% else %}
<body id="tags" class=" ">
{% endif %}
{% include "base/header.peb" %}
<div id="content-container">
    {% include "base/subnav.peb" %}
    <div id="container">
        <div id="content" style="position: relative" class="clearfix">
            <div id="column1" class="column">
                <div class="habblet-container ">
                    <div class="cbb clearfix default ">
                        <h2 class="title">Popular tags</h2>
                        <div id="tag-related-habblet-container" class="habblet box-contents">
                            <ul class="tag-list">
                            {% for tag in tagSearch.popularTags %}
                                <li><a href="{{ tag.url }}" class="tag" style="font-size:{{ tag.size }}%">{{ tag.name }}</a> </li>
                            {% endfor %}
                            </ul>
                        </div>
                    </div>
                </div>
                <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>

                <div class="habblet-container ">
                    <div class="cbb clearfix default ">
                        <h2 class="title">Tag fight</h2>
                        <div id="tag-fight-habblet-container">
                            <div class="fight-process" id="fight-process">Pick two tags and let them fight!</div>
                            <div id="fightForm" class="fight-form">
                                <div class="tag-field-container">First tag<br /><input maxlength="30" type="text" class="tag-input" name="tag1" id="tag1"/></div>
                                <div class="tag-field-container">Second tag<br /><input maxlength="30" type="text" class="tag-input" name="tag2" id="tag2"/></div>
                            </div>
                            <div id="fightResults" class="fight-results">
                                <div class="fight-image">
                                    <img src="{{ site.webGalleryPath }}/images/tagfight/tagfight_start.gif" alt="" name="fightanimation" id="fightanimation" />
                                    <a id="tag-fight-button" href="#" class="new-button" onclick="TagFight.init(); return false;"><b>Fight</b><i></i></a>
                                </div>
                            </div>
                            <div class="tagfight-preload">
                                <img src="{{ site.webGalleryPath }}/images/tagfight/tagfight_end_0.gif" width="1" height="1"/>
                                <img src="{{ site.webGalleryPath }}/images/tagfight/tagfight_end_1.gif" width="1" height="1"/>
                                <img src="{{ site.webGalleryPath }}/images/tagfight/tagfight_end_2.gif" width="1" height="1"/>
                                <img src="{{ site.webGalleryPath }}/images/tagfight/tagfight_loop.gif" width="1" height="1"/>
                                <img src="{{ site.webGalleryPath }}/images/tagfight/tagfight_start.gif" width="1" height="1"/>
                            </div>
                        </div>
                    </div>
                </div>
                <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>

                {% if session.loggedIn %}
                <div class="habblet-container ">
                    <div class="cbb clearfix default ">
                        <h2 class="title">Tag match</h2>
                        <div id="tag-match-habblet-container">
                            <div id="tag-match-result">
                                Enter a friend name to see how many tags you have in common.
                            </div>

                            <div id="tag-match-form">
                                <input type="text" id="tag-match-friend" value=""/>
                                <a class="new-button" id="tag-match-send" href="#"><b>Match</b><i></i></a>
                            </div>
                            <script type="text/javascript">
                            document.observe("dom:loaded", function() {
                                Event.observe($('tag-match-friend'), "keypress", function(e) {
                                    if (e.keyCode == Event.KEY_RETURN) {
                                        TagHelper.matchFriend();
                                    }
                                });
                                Event.observe($('tag-match-send'), "click", function(e) { Event.stop(e); TagHelper.matchFriend(); });
                            });
                            </script>
                        </div>
                    </div>
                </div>
                <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>
                {% endif %}
            </div>
            <div id="column2" class="column">
                <div class="habblet-container ">
                    <div class="cbb clearfix default ">
                        <h2 class="title">Tag search</h2>
                        {% include "habblet/tag_search_results.peb" %}
                    </div>
                </div>
                <script type="text/javascript">if (!$(document.body).hasClassName('process-template')) { Rounder.init(); }</script>
            </div>
        </div>
<script type="text/javascript">
HabboView.run();
</script>
{% include "base/footer.peb" %}
</body>
</html>
